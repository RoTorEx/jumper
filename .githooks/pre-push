#!/usr/bin/env sh
set -eu

# VIBE:KERNEL_MANAGED_HOOK
# Vibecoding Kernel managed hook.
# Runs repo-local lint gate before push.

if [ "${VIBE_SKIP_LINT_HOOKS:-}" = "1" ]; then
  exit 0
fi

if ! command -v make >/dev/null 2>&1; then
  echo "ERROR: 'make' not found; cannot run pre-push lint gate." >&2
  exit 1
fi

echo "[pre-push] make lint"
out="$(mktemp)"
if make lint >"$$out" 2>&1; then
  rm -f "$$out"
  exit 0
fi

if grep -Fq "TODO: implement lint only if real lint exists." "$$out"; then
  echo "[pre-push] lint target is a placeholder; skipping lint hook." >&2
  rm -f "$$out"
  exit 0
fi

cat "$$out" >&2
rm -f "$$out"
exit 1
